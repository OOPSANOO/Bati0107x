<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>SARL BATISYSTÈME - إدارة التسبيقات</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <style>
        :root {
            --bg-dark: #0f172a;
            --card-bg: #1e293b;
            --primary-gold: #c29343;
            --accent-blue: #3b82f6;
            --pdf-red: #ef4444;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --fb-blue: #1877F2;
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-main);
            margin: 0; padding: 0;
            display: flex; flex-direction: column; min-height: 100vh;
        }

        .app-shell {
            width: 100%; max-width: 500px; margin: 0 auto;
            padding: 15px; padding-bottom: 100px;
            position: relative;
        }

        .top-watermark {
            text-align: center; width: 100%; font-size: 10px; font-weight: bold;
            color: var(--primary-gold); letter-spacing: 2px; margin-bottom: 10px; opacity: 0.7;
        }

        header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; }
        .brand-container { display: flex; flex-direction: column; flex-grow: 1; }
        .brand-name { color: var(--primary-gold); font-size: 22px; font-weight: 900; margin: 0; line-height: 1; }
        
        .annexe-selector {
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--primary-gold);
            color: var(--text-main);
            padding: 5px;
            border-radius: 5px;
            font-size: 14px;
            font-weight: bold;
            margin-top: 8px;
            width: fit-content;
            outline: none;
        }

        .brand-sub { font-size: 11px; color: var(--text-muted); margin-top: 2px; }

        .fb-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: var(--fb-blue);
            color: white;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            text-decoration: none;
            margin-bottom: 5px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
            transition: transform 0.2s;
            cursor: pointer;
            border: none;
        }
        .fb-link:active { transform: scale(0.9); }
        .fb-icon { font-weight: bold; font-family: sans-serif; font-size: 18px; }

        .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 20px; }
        .stat-card { background: var(--card-bg); border-radius: 12px; padding: 10px 5px; text-align: center; border: 1px solid rgba(255,255,255,0.05); }
        .stat-label { color: var(--text-muted); font-size: 10px; display: block; }
        .stat-value { font-size: 14px; font-weight: bold; }

        .data-table { width: 100%; border-collapse: collapse; background: var(--card-bg); border-radius: 12px; overflow: hidden; font-size: 13px; }
        .data-table th { background: rgba(255,255,255,0.05); padding: 10px; color: var(--text-muted); text-align: right; }
        .data-table td { padding: 10px; border-bottom: 1px solid rgba(255,255,255,0.05); }

        .time-stamp { display: block; font-size: 9px; color: var(--accent-blue); margin-top: 2px; }

        .footer-actions {
            position: fixed; bottom: 0; left: 0; right: 0;
            background: #0b1120; padding: 12px;
            display: flex; gap: 8px; border-top: 1px solid rgba(255,255,255,0.1); z-index: 100;
        }
        .btn { border: none; border-radius: 10px; height: 45px; font-weight: bold; cursor: pointer; flex: 1; display: flex; align-items: center; justify-content: center; gap: 5px; color: white; }
        .btn-save { background: var(--primary-gold); color: #000; }
        .btn-pdf { background: var(--pdf-red); }
        .btn-add { background: var(--accent-blue); width: 50px; flex: none; border-radius: 50%; font-size: 24px; }

        #searchOverlay {
            position: fixed; inset: 0; background: rgba(15, 23, 42, 0.98); z-index: 200; display: none; padding: 20px;
        }
        .search-input { width: 100%; background: var(--card-bg); border: 1px solid var(--accent-blue); padding: 12px; border-radius: 10px; color: white; margin-bottom: 10px; outline: none; }
        
        .add-new-name-btn {
            width: 100%; background: rgba(59, 130, 246, 0.15); border: 1px dashed var(--accent-blue);
            color: var(--accent-blue); padding: 10px; border-radius: 10px; margin-bottom: 15px; cursor: pointer; font-weight: bold;
        }

        .name-item { 
            padding: 12px; border-bottom: 1px solid rgba(255,255,255,0.05); 
            display: flex; justify-content: space-between; align-items: center;
        }
        .name-text { flex-grow: 1; cursor: pointer; }
        .delete-name-btn { color: var(--pdf-red); font-size: 14px; padding: 5px; cursor: pointer; background: none; border: none; }

        #customModal { position: fixed; inset: 0; background: rgba(0,0,0,0.8); z-index: 300; display: none; align-items: center; justify-content: center; }
        .modal-content { background: var(--card-bg); padding: 20px; border-radius: 15px; width: 85%; max-width: 320px; }
        #toast { position: fixed; top: -50px; left: 50%; transform: translateX(-50%); background: #10b981; padding: 10px 20px; border-radius: 20px; font-size: 13px; transition: 0.4s; z-index: 400; }
        #toast.show { top: 20px; }
    </style>
</head>
<body>

<div id="toast">تمت العملية بنجاح</div>

<div class="app-shell" id="captureArea">
    <div class="top-watermark">BY OOPSANOO</div>

    <header>
        <div class="brand-container">
            <h1 class="brand-name">SARL BATISYSTÈME</h1>
            <select id="projectSelect" class="annexe-selector hide-exp" onchange="changeProject()">
                <option value="ANNEXE N°08 TRAVERSA">ANNEXE N°08 TRAVERSA</option>
                <option value="ANNEXE N°01">ANNEXE N°01</option>
                <option value="ANNEXE N°07">ANNEXE N°07</option>
            </select>
            <span id="projectDisplay" style="display:none; color: var(--text-main); font-size: 14px; font-weight: bold; margin-top: 4px;"></span>
            <p class="brand-sub">إدارة التسبيقات الرقمية</p>
        </div>
        
        <div style="text-align: left; display: flex; flex-direction: column; align-items: flex-end;">
            <button onclick="openFacebookApp()" class="fb-link hide-exp" id="fbIcon">
                <span class="fb-icon">f</span>
            </button>
            <span id="liveDate" style="font-size: 11px; color: var(--text-muted);"></span>
        </div>
    </header>

    <div class="stats-grid">
        <div class="stat-card"><span class="stat-label">العمال</span><span class="stat-value" id="countVal">0</span></div>
        <div class="stat-card" style="border: 1px solid var(--primary-gold);"><span class="stat-label">المجموع</span><span class="stat-value" id="totalVal">0 DA</span></div>
        <div class="stat-card"><span class="stat-label">توقيت التقرير</span><span class="stat-value" id="timeVal">00:00</span></div>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th style="width:20px">#</th>
                <th>اسم العامل والتاريخ</th>
                <th>المبلغ</th>
                <th class="hide-exp" style="width:30px"></th>
            </tr>
        </thead>
        <tbody id="tableBody"></tbody>
    </table>
</div>

<div class="footer-actions">
    <button class="btn btn-save" onclick="exportImage()">📸 صورة</button>
    <button class="btn btn-add" onclick="showSearch()">+</button>
    <button class="btn btn-pdf" onclick="exportPDF()">📄 PDF</button>
</div>

<script>
    // الدالة الجديدة لفتح التطبيق مباشرة
    function openFacebookApp() {
        const fbPageUrl = "https://www.facebook.com/share/1Dwgwxo2SU/";
        // بروتوكول الروابط العميقة لفيسبوك
        const fbAppProtocol = "fb://facewebmodal/f?href=" + fbPageUrl;

        // محاولة فتح التطبيق
        window.location.href = fbAppProtocol;

        // إذا لم يفتح التطبيق خلال نصف ثانية، افتح الرابط في المتصفح
        setTimeout(function() {
            window.open(fbPageUrl, '_blank');
        }, 500);
    }

    // ... (بقية دوال JavaScript الأصلية الخاصة بك) ...
    let currentProject = "ANNEXE N°08 TRAVERSA";
    let workerData = []; 
    
    // (باقي الكود كما هو دون تغيير في المنطق الداخلي)
    const defaultLists = {
        "ANNEXE N°08 TRAVERSA": ["عمران محمد", "منصوري حميد", "ينصالي عبد القادر", "حمراوي امين", "عبيد محمد", "حماد الزبير", "شرماط فؤاد", "قبايلي محمد", "بوزياني محي الدين", "زرميش", "حمراوي علي", "مفتاح حبيب", "مسيد محمد", "بن الدين فضيلة", "خلفي نور الدين", "كداد محمد"],
        "ANNEXE N°01": [], "ANNEXE N°07": []
    };
    let searchableNames = [];
    function init() {
        const lastProject = localStorage.getItem('bt_current_project');
        if(lastProject) currentProject = lastProject;
        document.getElementById('projectSelect').value = currentProject;
        loadProjectData();
        document.getElementById('liveDate').textContent = new Date().toLocaleDateString('ar-DZ');
    }
    function loadProjectData() {
        const d = localStorage.getItem(`bt_data_${currentProject}`);
        workerData = d ? JSON.parse(d) : [];
        const n = localStorage.getItem(`bt_names_${currentProject}`);
        searchableNames = n ? JSON.parse(n) : [...defaultLists[currentProject]];
        document.getElementById('searchTitle').textContent = `قائمة عمال ${currentProject}`;
        render();
    }
    function changeProject() {
        currentProject = document.getElementById('projectSelect').value;
        localStorage.setItem('bt_current_project', currentProject);
        loadProjectData();
        showToast(`تم الانتقال إلى ${currentProject}`);
    }
    function showToast(msg, isError = false) {
        const t = document.getElementById('toast');
        t.textContent = msg; t.style.background = isError ? "#ef4444" : "#10b981";
        t.classList.add('show'); setTimeout(() => t.classList.remove('show'), 2500);
    }
    function showSearch() { document.getElementById('searchOverlay').style.display = 'block'; filterNames(); }
    function hideSearch() { document.getElementById('searchOverlay').style.display = 'none'; }
    function addNewNamePrompt() {
        const newName = prompt(`إضافة عامل جديد لـ ${currentProject}:`);
        if(newName && newName.trim() !== "") {
            const cleanName = newName.trim();
            if(searchableNames.some(n => n.toLowerCase() === cleanName.toLowerCase())) {
                alert("خطأ: هذا الاسم موجود بالفعل في القائمة!");
            } else {
                searchableNames.push(cleanName);
                localStorage.setItem(`bt_names_${currentProject}`, JSON.stringify(searchableNames));
                filterNames(); showToast("تمت إضافة الاسم بنجاح");
            }
        }
    }
    function filterNames() {
        const q = document.getElementById('searchInput').value.toLowerCase();
        const list = document.getElementById('namesList'); list.innerHTML = '';
        searchableNames.forEach((name, index) => {
            if(name.toLowerCase().includes(q)) {
                const div = document.createElement('div'); div.className = 'name-item';
                div.innerHTML = `<span class="name-text" onclick="requestAmount('${name}')">${name}</span><button class="delete-name-btn" onclick="deleteNameFromList(${index}, event)">🗑️</button>`;
                list.appendChild(div);
            }
        });
    }
    function requestAmount(name) {
        if(workerData.some(w => w.name === name)) { alert(`خطأ: العامل "${name}" مضاف بالفعل!`); return; }
        document.getElementById('modalTitle').textContent = `تسبيق: ${name}`;
        document.getElementById('customModal').style.display = 'flex';
        document.getElementById('modalInput').value = '';
        document.getElementById('modalConfirmBtn').onclick = () => {
            const amt = document.getElementById('modalInput').value;
            if(amt) {
                const now = new Date();
                const timeStr = now.getHours() + ":" + now.getMinutes().toString().padStart(2, '0');
                const dateStr = now.getDate() + "/" + (now.getMonth()+1);
                workerData.push({ name, amount: parseInt(amt), time: timeStr, date: dateStr });
                saveAndRender(); closeModal(); hideSearch();
            }
        };
    }
    function closeModal() { document.getElementById('customModal').style.display = 'none'; }
    function deleteRow(i) { if(confirm("حذف هذا السجل؟")) { workerData.splice(i, 1); saveAndRender(); } }
    function saveAndRender() { localStorage.setItem(`bt_data_${currentProject}`, JSON.stringify(workerData)); render(); }
    function render() {
        const tbody = document.getElementById('tableBody'); tbody.innerHTML = ''; let total = 0;
        workerData.forEach((w, i) => {
            total += w.amount; const tr = document.createElement('tr');
            tr.innerHTML = `<td style="color:var(--text-muted)">${i+1}</td><td><strong>${w.name}</strong><span class="time-stamp">📅 ${w.date} | 🕒 ${w.time}</span></td><td style="font-weight:bold; color:var(--primary-gold)">${w.amount.toLocaleString()}</td><td class="hide-exp"><button onclick="deleteRow(${i})" style="background:none; border:none; color:var(--pdf-red); cursor:pointer;">✕</button></td>`;
            tbody.appendChild(tr);
        });
        document.getElementById('totalVal').textContent = total.toLocaleString() + " DA";
        document.getElementById('countVal').textContent = workerData.length;
        document.getElementById('timeVal').textContent = new Date().getHours() + ":" + new Date().getMinutes().toString().padStart(2, '0');
    }
    async function prepareForExport(isExporting) {
        const select = document.getElementById('projectSelect'); const display = document.getElementById('projectDisplay');
        if(isExporting) {
            display.textContent = select.value; display.style.display = 'block';
            document.querySelectorAll('.hide-exp').forEach(el => el.style.display = 'none');
        } else {
            display.style.display = 'none';
            document.querySelectorAll('.hide-exp').forEach(el => {
                if(el.tagName === 'SELECT' || el.tagName === 'BUTTON') el.style.display = 'block';
                else if(el.tagName === 'A') el.style.display = 'inline-flex';
                else el.style.display = 'table-cell';
            });
        }
    }
    async function exportImage() {
        await prepareForExport(true);
        const canvas = await html2canvas(document.getElementById('captureArea'), { backgroundColor: '#0f172a', scale: 3 });
        const link = document.createElement('a'); link.download = `${currentProject}_${Date.now()}.png`;
        link.href = canvas.toDataURL(); link.click();
        await prepareForExport(false);
    }
    async function exportPDF() {
        const { jsPDF } = window.jspdf; await prepareForExport(true);
        const canvas = await html2canvas(document.getElementById('captureArea'), { backgroundColor: '#0f172a', scale: 3 });
        const imgData = canvas.toDataURL('image/png'); const pdf = new jsPDF('p', 'mm', 'a4');
        const pdfWidth = pdf.internal.pageSize.getWidth();
        const pdfHeight = (canvas.height * pdfWidth) / canvas.width;
        pdf.addImage(imgData, 'PNG', 0, 0, pdfWidth, pdfHeight);
        pdf.save(`${currentProject}_Report.pdf`); await prepareForExport(false);
    }
    init();
</script>
</body>
</html>

